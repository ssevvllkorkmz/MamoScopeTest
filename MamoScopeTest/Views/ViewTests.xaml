<UserControl x:Class="MamoScopeTest.Views.ViewTests"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MamoScopeTest.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                   Text="GEÇMİŞ KAYITLAR" FontSize="22" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="10,10,10,20"/>

        <Button x:Name="YeniTest" Grid.Row="0" Grid.Column="3" 
                Content="Yeni Test" FontSize="16" Height="35" Width="130"
                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,10,10,20"
                Command="{Binding YeniTestCommand}"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Seri Numarası" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
        <Label Grid.Row="1" Grid.Column="1" Content="Voltaj Değeri" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
        <Label Grid.Row="1" Grid.Column="2" Content="Tarih" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
        <Label Grid.Row="1" Grid.Column="3" Content="Test Sonucu" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>

        <Border Grid.Row="1" Grid.ColumnSpan="4" BorderBrush="LightGray" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

        <ScrollViewer Grid.Row="2" Grid.ColumnSpan="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding GecmisTestler}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding SerialNumber}" FontSize="16" Foreground="DimGray" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Voltage, StringFormat='{}{0} V'}" FontSize="16" Foreground="DimGray" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding TestDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" FontSize="16" Foreground="DimGray" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>

                            <TextBlock Grid.Column="3" FontSize="16" FontWeight="Medium" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="BAŞARISIZ"/>
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                <Setter Property="Text" Value="BAŞARILI"/>
                                                <Setter Property="Foreground" Value="Green"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>