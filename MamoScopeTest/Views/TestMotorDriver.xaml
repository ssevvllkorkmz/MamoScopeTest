<UserControl x:Class="MamoScopeTest.Views.TestMotorDriver"
             xmlns:vms="clr-namespace:MamoScopeTest.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MamoScopeTest.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vms:TestKayıtViewModel/>
    </UserControl.DataContext>

    <Grid Background="White">


        <TextBlock Text="Seri Numarası:" FontSize="15" HorizontalAlignment="Left" Margin="10,70,0,0" VerticalAlignment="Top"/>
        <TextBox Text="{Binding SeriNumarası, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" FontSize="15" HorizontalAlignment="Left" Height="25" Margin="10,93,0,0" VerticalAlignment="Top" Width="390" />

        <TextBlock Text="Voltaj Değeri:" FontSize="15" HorizontalAlignment="Left" Margin="10,125,0,0" VerticalAlignment="Top"/>
        <TextBox Text="{Binding VoltajDegeri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="15" HorizontalAlignment="Left" Height="25" Margin="10,149,0,0" VerticalAlignment="Top" Width="390" />

        <TextBlock Text="Tarih:" FontSize="15" HorizontalAlignment="Left" Margin="10,180,0,0" VerticalAlignment="Top"/>
        <TextBox Text="{Binding Tarih, UpdateSourceTrigger=PropertyChanged}" FontSize="15" HorizontalAlignment="Left" Height="25" Margin="10,205,0,0" VerticalAlignment="Top" Width="390" />

        <TextBlock Text="{Binding TestSonucu}" FontSize="18" FontWeight="Bold" Foreground="DarkBlue" HorizontalAlignment="Left" Margin="10,245,0,0" VerticalAlignment="Top" Width="390"/>

        <Button x:Name="GecmisTestler" Content="Geçmiş Testleri Görüntüle" Command="{Binding GecmisTestlerCommand}" FontSize="18" HorizontalAlignment="Left" Height="44" Margin="10,290,0,0" VerticalAlignment="Top" Width="240"/>
        <Button x:Name="TestEt" Content="Test Et" Command="{Binding TestEtCommand}" FontSize="18" HorizontalAlignment="Left" Height="44" Margin="274,290,0,0" VerticalAlignment="Top" Width="126" />
        <Button Content="Test Verisi Simüle Et" 
        Command="{Binding SimuleEtCommand}" 
        Height="40" Width="200" FontSize="16" FontWeight="Bold" 
        Background="LightBlue" Margin="130,358,470,52"/>

    </Grid>
</UserControl>